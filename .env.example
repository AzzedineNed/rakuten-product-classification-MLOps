# Copy this file to ".env" and fill in your own values.
# .env is gitignored and must NEVER be committed.

# ENS Challenge Data credentials (used by: collect.py --from-ens)
ENS_USERNAME=your_ens_username
ENS_PASSWORD=your_ens_password

# Optional overrides (defaults shown)
# ENS_CHALLENGE_ID=35
# RAKUTEN_CLASSIFIER=mlp

MLFLOW_TRACKING_URI=https://dagshub.com/azzedinenedjai95/rakuten-product-classification-MLOps.mlflow
MLFLOW_TRACKING_USERNAME=azzedinenedjai95
MLFLOW_TRACKING_PASSWORD=<your default DagsHub token>