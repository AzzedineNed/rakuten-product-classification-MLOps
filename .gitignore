# Data & artifacts (never commit these)
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
models/*
!models/.gitkeep
reports/*
!reports/.gitkeep

# DVC internals: .dvc/.gitignore (written by DVC) already ignores
# config.local (token), tmp/ and cache/. .dvc/config MUST be committed
# so teammates get the remote definition and `dvc pull` works.

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# Tooling
.pytest_cache/
.ipynb_checkpoints/
.DS_Store